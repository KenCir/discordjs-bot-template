{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "discordjs-bot-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc",
		"lint": "prettier --check . && eslint --ext .ts --format=pretty src",
		"deploy": "node --env-file=.env dist/util/deploy.js",
		"format": "prettier --write . && eslint --ext .ts --fix --format=pretty src",
		"start": "node --env-file=.env dist/index.js"
	},
	"dependencies": {
		"@discordjs/core": "^2.4.0",
		"bufferutil": "^4.1.0",
		"discord.js": "^14.26.4",
		"zlib-sync": "^0.1.10"
	},
	"devDependencies": {
		"@sapphire/ts-config": "^5.0.3",
		"@types/node": "^22.19.18",
		"eslint": "^9.39.4",
		"eslint-config-neon": "^0.4.0",
		"eslint-formatter-compact": "^8.40.0",
		"eslint-formatter-pretty": "^7.1.0",
		"prettier": "^3.8.3",
		"typescript": "~5.9.3",
		"zod": "^3.25.76"
	},
	"engines": {
		"node": ">=22.12.0"
	}
}
